# Порт для Express-сервера
PORT=3000

# Gemini API ключі. Можна вказати один або декілька через кому — система автоматично
# перемикатиметься між ними при вичерпанні денної квоти (RPD).
# Отримати ключі: https://aistudio.google.com/app/apikey
# Для більших лімітів створіть ключі у РІЗНИХ Google-акаунтах.
GEMINI_API_KEY=your_gemini_api_key_here
# Можна додати декілька через кому:
# GEMINI_API_KEY=key1,key2,key3

# Модель Gemini.
# УВАГА: у грудні 2025 Google скоротив безкоштовні ліміти. Поточні значення:
#   gemini-2.5-flash-lite  — 15 RPM, ~1000 запитів/добу (НАЙКРАЩА для free-tier)
#   gemini-2.5-flash       — 10 RPM, ~250 запитів/добу (раніше було 1500)
#   gemini-2.5-pro         — 5 RPM, ~50 запитів/добу
# У деяких регіонах/нових акаунтів ліміти ще нижчі (~20/добу).
GEMINI_MODEL=gemini-2.5-flash-lite
