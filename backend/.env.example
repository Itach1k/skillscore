# Порт для Express-сервера
PORT=3000

# Gemini API ключ (отримати на https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Модель Gemini.
# Станом на травень 2026 на безкоштовному тарифі доступні:
#   gemini-2.5-flash-lite  — 15 RPM, 1000 запитів/добу (рекомендовано)
#   gemini-2.5-flash       — 10 RPM, 250 запитів/добу (вища якість)
#   gemini-2.5-pro         — 5 RPM, 50 запитів/добу (скупо, лише для тестів)
# УВАГА: gemini-2.0-flash і gemini-1.5-flash виведено з free-tier у 2026 році.
GEMINI_MODEL=gemini-2.5-flash-lite
